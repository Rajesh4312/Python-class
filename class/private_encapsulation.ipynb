    "class Employee:\n",
    "    def __init__(self, name, salary):\n",
    "        self.name = name  # Public\n",
    "        self.__salary = salary  # Private (double underscore)\n",
    "    def display(self):\n",
    "        print(self.__salary)\n",
    "\n",
    "emp = Employee(\"Charlie\", 60000)\n",
    "emp.display()\n",
    "\n"
   ]
